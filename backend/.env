# Environment variables for the backend

# Server configuration
PORT=5000
NODE_ENV=development

# MongoDB connection
MONGO_URI=mongodb://127.0.0.1:27017/photography


# JWT Secret for authentication (if applicable)
JWT_SECRET=your_jwt_secret_here

# Email service configuration (for nodemailer)
EMAIL_HOST=your_email_host_e.g._smtp.mailtrap.io
EMAIL_PORT=your_email_port_e.g._2525
EMAIL_USER=your_email_username
EMAIL_PASS=your_email_password
EMAIL_FROM=your_sender_email_e.g._info@example.com
EMAIL_SECURE=false # Use 'true' for SSL/TLS, 'false' for STARTTLS or no encryption

# Admin email for notifications (used in bookingController)
ADMIN_EMAIL=admin@example.com

# Cloudinary for image uploads (if applicable)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
